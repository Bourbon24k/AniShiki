# Supabase — для аккаунта AniShiki и совместного просмотра.
# Без этих переменных сайт работает как раньше (только аккаунт Anixart),
# а фичи аккаунта/совместного просмотра скрыты.
# Значения: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-KEY
